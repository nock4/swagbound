{
  "name": "coilsnake-tutorial-experiment",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @eb/game dev",
    "convert": "pnpm --filter @eb/converter convert",
    "validate": "pnpm --filter @eb/converter validate",
    "test": "vitest run",
    "proof:check": "tsx scripts/proof-check.ts",
    "proof:check:bedroom": "tsx scripts/proof-check.ts --expect-placement bedroom",
    "proof:check:roadblock-706": "tsx scripts/proof-check.ts --expect-placement roadblock-706",
    "proof:check:roadblock-706-clean-doors": "tsx scripts/proof-check.ts --expect-placement roadblock-706 --allow-map-door-text",
    "proof:check:roadblock-707": "tsx scripts/proof-check.ts --expect-placement roadblock-707",
    "proof:check:roadblock-707-clean-doors": "tsx scripts/proof-check.ts --expect-placement roadblock-707 --allow-map-door-text",
    "proof:snapshot": "tsx scripts/proof-check.ts --snapshot",
    "proof:safety": "tsx scripts/proof-check.ts --safety",
    "proof:status": "tsx scripts/proof-check.ts --status",
    "proof:packet": "tsx scripts/proof-packet.ts",
    "proof:packet:bedroom": "tsx scripts/proof-packet.ts --mode bedroom",
    "proof:packet:roadblock-706": "tsx scripts/proof-packet.ts --mode roadblock-706",
    "proof:packet:roadblock-706-clean-doors": "tsx scripts/proof-packet.ts --mode roadblock-706-clean-doors",
    "proof:packet:roadblock-707": "tsx scripts/proof-packet.ts --mode roadblock-707",
    "proof:packet:roadblock-707-clean-doors": "tsx scripts/proof-packet.ts --mode roadblock-707-clean-doors",
    "proof:packet:roadblock-706:diagnostic": "tsx scripts/proof-packet.ts --mode roadblock-706 --allow-fail --out .codex/proof-packets/roadblock-706-diagnostic.md",
    "proof:packet:roadblock-707:diagnostic": "tsx scripts/proof-packet.ts --mode roadblock-707 --allow-fail --out .codex/proof-packets/roadblock-707-diagnostic.md",
    "pretest:review": "pnpm convert && pnpm validate",
    "test:review": "playwright test --project review-chromium",
    "test:replay": "playwright test --project replay-chromium",
    "show:review": "playwright show-report playwright-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@replayio/playwright": "^5.0.3",
    "@types/node": "^20.14.11",
    "dotenv": "^17.4.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "phaser": "^4.1.0",
    "zod": "^3.23.8"
  }
}
