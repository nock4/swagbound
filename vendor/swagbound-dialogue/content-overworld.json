            ]
          }
        },
        {
          "id": "north-civic-mailbox",
          "definition": "object-check",
          "source_id": "north-civic-mailbox",
          "interaction": {
            "id": "north-civic-mailbox-check",
            "speaker": "Mailbox",
            "duration_seconds": 1.5,
            "lines": [
              "A folded notice lists BOSCH? as seen near north park.",
              "Witness line: pending. The envelope is warm like it remembers the trial."
            ]
          }
        },
        {
          "id": "south-office-mailbox",
          "definition": "item-cache",
          "source_id": "south-office-mailbox",
          "event_flag": "act1.cache.south_office_mailbox_claimed",
