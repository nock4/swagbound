            "give_swag": 2,
            "duration_seconds": 1.5,
            "lines": [
              "A receipt is stamped SOUTH PARK COMPLIANCE.",
              "There are 2 Swag tucked behind it and a checkbox labeled REACTED PROPERLY."
            ]
          }
        },
        {
          "id": "market-utility-pole",
          "definition": "object-check",
          "source_id": "market-utility-pole",
          "interaction": {
            "id": "market-utility-pole-check",
            "speaker": "Utility Pole",
            "duration_seconds": 1.5,
            "lines": [
              "The pole hums: PUBLIC VERSION FOUND.",
              "SOURCE: PRESENT, BUT CONTESTING."
            ]
          }
        },
        {
          "id": "east-shop-mailbox-cache",
