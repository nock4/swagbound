            "speaker": "Marked Crate",
            "duration_seconds": 1.6,
            "lines": [
              "Fresh towels. Fresh uniforms. Fresh public versions of everybody.",
              "The label peels off before Bosch can read who the delivery was for."
            ]
          }
        }
