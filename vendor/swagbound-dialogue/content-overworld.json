        {
          "id": "sunline-bellhop",
          "definition": "neighbor-idle-south",
          "source_id": "north-office-kid",
          "interaction": {
            "id": "sunline-bellhop-talk",
            "speaker": "Sunline Bellhop",
            "duration_seconds": 1.8,
            "lines": [
              "Everybody smiles at the exact same tempo out here.",
              "If the promenade stays this calm, the calm is the problem."
            ]
          }
        },
        {
          "id": "coral-patio-host",
          "definition": "neighbor-idle-south",
          "source_id": "north-shop-neighbor",
          "interaction": {
            "id": "coral-patio-host-talk",
            "speaker": "Patio Host",
            "duration_seconds": 1.8,
            "lines": [
              "The umbrellas make the strip feel social even when nobody is really talking.",
              "Stay where the light says you belong."
            ]
          }
        },
        {
          "id": "service-runner",
          "definition": "kid-route",
          "source_id": "north-sidewalk-kid",
          "route_tiles": [
