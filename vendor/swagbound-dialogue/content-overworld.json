          "interaction": {
            "id": "woods-neighbor-talk",
            "speaker": "Woods Neighbor",
            "duration_seconds": 1.9,
            "lines": [
              "Out here the signal gets lazy.",
              "It still knows which version of Bosch the town prefers."
            ]
          }
        },
        {
          "id": "trail-kid",
