          ],
          "interaction": {
            "id": "service-runner-talk",
            "speaker": "Service Runner",
            "duration_seconds": 1.9,
            "lines": [
              "Behind the facades, every cart knows where it is supposed to wait.",
              "The lane remembers you faster than the strip does."
            ]
          }
        },
        {
          "id": "promenade-viewer",
          "definition": "kid-idle-south",
          "source_id": "shop-front-neighbor",
          "interaction": {
            "id": "promenade-viewer-talk",
            "speaker": "Promenade Viewer",
            "duration_seconds": 1.8,
            "lines": [
              "The water is bright enough to look fake from here.",
              "I keep checking whether the horizon moved first or me."
            ]
          }
        },
